" Leader key
let mapleader = " "
let maplocalleader = " "

" easymotion/anyobject not enabled: sneak covers easymotion, mini-ai covers anyobject.
" surround: vim-surround keys (ys/cs/ds) match Zed native + mini.surround; `s` stays free for sneak.

" General settings
set clipboard+=unnamedplus
set notimeout
set number
set scrolloff=5
set sidescrolloff=5

" Search settings
set ignorecase
set smartcase
set incsearch
set hlsearch

" IdeaVim plugins
set commentary
set highlightedyank
set nerdtree
set mini-ai
set sneak
set easymotion
set surround
set VimEverywhere

" ── LSP g-family (matches Neovim 0.12 + Zed) ───────────────────────────
nmap gd  <Action>(GotoDeclaration)
nmap gD  <Action>(GotoDeclaration)
nmap grn <Action>(RenameElement)
map  gra <Action>(ShowIntentionActions)
nmap grr <Action>(FindUsages)
nmap gri <Action>(GotoImplementation)
nmap grt <Action>(GotoTypeDeclaration)
nmap gO  <Action>(FileStructurePopup)
nmap gS  <Action>(GotoSymbol)
nmap K   <Action>(ShowHoverInfo)
imap <C-s> <Action>(ParameterInfo)
nmap ]d  <Action>(GotoNextError)
nmap [d  <Action>(GotoPreviousError)
nmap <C-w>d <Action>(ShowErrorDescription)

" ── Space leader ───────────────────────────────────────────────────────
map <leader><space> <Action>(SearchEverywhere)
map <leader>f <Action>(GotoFile)
map <leader>g <Action>(FindInPath)
map <leader>b <Action>(RecentFiles)
map <leader>e <Action>(SelectInProjectView)
map <leader>s <Action>(GotoSymbol)
map <leader>v <Action>(ActivateVersionControlToolWindow)
map <leader>t <Action>(ActivateTerminalToolWindow)
map <leader>d <Action>(ActivateProblemsViewToolWindow)
nmap <leader>R <Action>(IdeaVim.ReloadVimRc.reload)

" Let vim own Ctrl-W (splits), not Extend Selection
sethandler <C-W> a:vim

" Let the IDE handle ctrl+n/p/y for popup navigation (code actions, completions)
sethandler <C-n> n:vim i:ide v:ide
sethandler <C-p> n:vim i:ide v:ide
sethandler <C-y> n:vim i:ide v:ide

" Paste in visual mode without yanking replaced text
xmap p "_dP
