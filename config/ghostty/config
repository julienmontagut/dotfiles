# Icon
macos-icon = custom-style
macos-icon-ghost-color = #c4a2e0
macos-icon-screen-color = #7ca2d8

# Theme
theme = basalt-dark

# Opacity
background-opacity = 0.95

# Font
font-family = Lilex
font-size = 16

# Shell
# initial-command = /bin/zsh -l -c "exec sesh picker -itzHd"

# Keybindings
# keybind = super+shift+n=new_window
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
