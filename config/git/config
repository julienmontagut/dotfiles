[user]
	name = Julien Montagut
	email = _@julienmontagut.com

[init]
	defaultBranch = main

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[rebase]
	autoStash = true

[fetch]
	all = true

[help]
	autocorrect = prompt

[submodule]
	recurse = true

[core]
	autocrlf = input

[merge]
	conflictstyle = diff3

[diff]
	colorMoved = default


# Maintenance settings
[maintenance]
	auto = true
	strategy = incremental
[color]
	ui = auto
